{
  "name": "prohor-analytics",
  "version": "2.16.2",
  "description": "A simple, fast, privacy-focused alternative to Google Analytics.",
  "author": "Prohor Analytics <hello@prohor.ai>",
  "license": "MIT",
  "homepage": "https://prohor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/prohor-analytics/prohor-analytics.git"
  },
  "type": "module",
  "scripts": {
    "dev": "dotenv next dev --turbo",
    "build": "npm-run-all check-env build-db check-db build-tracker build-recorder build-geo build-app",
    "start": "next start",
    "start-env": "node scripts/start-env.js",
    "start-server": "node server.js",
    "build-app": "next build --turbo",
    "build-icons": "svgr ./src/assets --out-dir src/components/svg --typescript",
    "build-tracker": "rollup -c rollup.tracker.config.js",
    "build-recorder": "rollup -c rollup.recorder.config.js",
    "build-prisma-client": "node scripts/build-prisma-client.js",
    "build-lang": "npm-run-all download-country-names download-language-names",
    "build-geo": "node scripts/build-geo.js",
    "build-db": "npm-run-all build-db-client build-prisma-client",
    "build-db-schema": "prisma db pull",
    "build-db-client": "prisma generate",
    "update-tracker": "node scripts/update-tracker.js",
    "update-db": "prisma migrate deploy",
    "check-db": "node scripts/check-db.js",
    "check-env": "node scripts/check-env.js",
    "check-missing-messages": "node scripts/check-missing-messages.js",
    "download-language-names": "node scripts/download-language-names.js",
    "change-password": "node scripts/change-password.js",
    "postbuild": "node scripts/postbuild.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write"
  },
  "cacheDirectories": [
    ".next/cache"
  ],
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-read-replicas": "^0.5.0",
    "@react-spring/web": "^10.1.0",
    "@svgr/cli": "^8.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@umami/react-zen": "^0.245.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "classnames": "^2.5.1",
    "colord": "^2.9.3",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^1.3.8",
    "debug": "^4.4.3",
    "detect-browser": "^5.3.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.7",
    "immer": "^11.1.8",
    "ipaddr.js": "^2.4.0",
    "is-localhost-ip": "^2.0.0",
    "isbot": "^5.1.42",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "maxmind": "^5.0.6",
    "next": "16.2.6",
    "next-intl": "4.9.2",
    "npm-run-all": "^4.1.5",
    "papaparse": "^5.5.3",
    "prisma": "^7.8.0",
    "pure-rand": "^7.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^4.1.2",
    "react-resizable-panels": "^4.11.2",
    "react-simple-maps": "^2.3.0",
    "react-window": "^1.8.11",
    "redis": "^4.7.1",
    "rrweb": "2.0.0-alpha.4",
    "rrweb-player": "1.0.0-alpha.4",
    "semver": "^7.8.3",
    "serialize-error": "^12.0.0",
    "thenby": "^1.4.1",
    "ua-parser-js": "^2.0.10",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^5.0.7",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.15",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "7.8.3",
    "rollup": "^4.61.1",
    "tar": "^7.5.16",
    "typescript": "^5.9.3"
  }
}
